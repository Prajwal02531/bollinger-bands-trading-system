//@version=5
strategy(
     title            = "Bollinger Bands Trading System — IDBI Bank",
     shorttitle        = "BB Trading System",
     overlay           = true,
     initial_capital   = 10000,
     currency          = currency.INR,
     default_qty_type  = strategy.percent_of_equity,
     default_qty_value = 10,
     commission_type   = strategy.commission.percent,
     commission_value  = 0.1,
     slippage          = 2
     )

// ─────────────────────────────────────────────
// INPUTS
// ─────────────────────────────────────────────
grp1 = "Bollinger Band Settings"
bb_length   = input.int(20,    title="SMA Period (n)",         group=grp1, minval=1)
bb_mult     = input.float(2.0, title="Std Dev Multiplier (k)", group=grp1, step=0.1)
bb_src      = input.source(close, title="Source",              group=grp1)

grp2 = "Risk Management"
stop_loss_pct = input.float(2.0, title="Stop Loss %",          group=grp2, step=0.1) / 100

grp3 = "Display"
show_bands  = input.bool(true,  title="Show Bollinger Bands",  group=grp3)
show_fill   = input.bool(true,  title="Show Band Fill",        group=grp3)
show_signals= input.bool(true,  title="Show Buy/Sell Signals", group=grp3)


// ─────────────────────────────────────────────
// BOLLINGER BAND CALCULATION
// ─────────────────────────────────────────────
// Equation (1): SMAₜ = (1/n) Σ Pₜ₋ᵢ
sma = ta.sma(bb_src, bb_length)

// Equation (2): σₜ = sqrt[(1/n) Σ (Pₜ₋ᵢ - SMAₜ)²]
dev = ta.stdev(bb_src, bb_length)

// Equation (3): UBₜ = SMAₜ + k*σₜ
upper_band = sma + bb_mult * dev

// Equation (4): LBₜ = SMAₜ - k*σₜ
lower_band = sma - bb_mult * dev


// ─────────────────────────────────────────────
// PLOT BOLLINGER BANDS
// ─────────────────────────────────────────────
upper_plot = plot(show_bands ? upper_band : na,
     title="Upper Band",
     color=color.new(color.red, 20),
     linewidth=2)

sma_plot = plot(show_bands ? sma : na,
     title="SMA (Middle Band)",
     color=color.new(color.yellow, 20),
     linewidth=1,
     style=plot.style_line)

lower_plot = plot(show_bands ? lower_band : na,
     title="Lower Band",
     color=color.new(color.green, 20),
     linewidth=2)

// Band fill
fill(upper_plot, lower_plot,
     color=show_fill ? color.new(color.blue, 93) : na,
     title="Band Fill")


// ─────────────────────────────────────────────
// SIGNAL GENERATION
// ─────────────────────────────────────────────
// Equation (5): Buy Signal — Price crosses below Lower Band
// Pₜ < LBₜ AND Pₜ₋₁ >= LBₜ₋₁
buy_signal  = close < lower_band and close[1] >= lower_band[1]

// Equation (6): Sell Signal — Price crosses above Upper Band
// Pₜ > UBₜ AND Pₜ₋₁ <= UBₜ₋₁
sell_signal = close > upper_band and close[1] <= upper_band[1]


// ─────────────────────────────────────────────
// STRATEGY EXECUTION
// ─────────────────────────────────────────────
// Only enter if no active position
if buy_signal and strategy.position_size == 0
    strategy.entry("Long", strategy.long)

if sell_signal and strategy.position_size == 0
    strategy.entry("Short", strategy.short)


// ─────────────────────────────────────────────
// EXIT STRATEGY
// ─────────────────────────────────────────────
// Equation (7): Long Exit — Price reaches SMA (Mean Reversion)
if strategy.position_size > 0
    // Mean-reversion exit
    strategy.exit("Long Exit",
         from_entry = "Long",
         stop       = strategy.position_avg_price * (1 - stop_loss_pct),
         limit      = sma)

// Equation (8): Short Exit — Price reaches SMA (Mean Reversion)
if strategy.position_size < 0
    // Mean-reversion exit
    strategy.exit("Short Exit",
         from_entry = "Short",
         stop       = strategy.position_avg_price * (1 + stop_loss_pct),
         limit      = sma)


// ─────────────────────────────────────────────
// PLOT SIGNALS ON CHART
// ─────────────────────────────────────────────
plotshape(show_signals and buy_signal,
     title    = "Buy Signal",
     location = location.belowbar,
     style    = shape.labelup,
     color    = color.new(color.green, 0),
     text     = "BUY",
     textcolor= color.white,
     size     = size.small)

plotshape(show_signals and sell_signal,
     title    = "Sell Signal",
     location = location.abovebar,
     style    = shape.labeldown,
     color    = color.new(color.red, 0),
     text     = "SELL",
     textcolor= color.white,
     size     = size.small)


// ─────────────────────────────────────────────
// BACKGROUND HIGHLIGHT — Active Position
// ─────────────────────────────────────────────
in_long  = strategy.position_size > 0
in_short = strategy.position_size < 0

bgcolor(in_long  ? color.new(color.green, 95) : na, title="Long Position BG")
bgcolor(in_short ? color.new(color.red,   95) : na, title="Short Position BG")


// ─────────────────────────────────────────────
// INFO TABLE (top right)
// ─────────────────────────────────────────────
var table info = table.new(position.top_right, 2, 7,
     border_width     = 1,
     border_color     = color.new(color.gray, 60),
     bgcolor          = color.new(color.black, 70))

if barstate.islast
    // Header
    table.cell(info, 0, 0, "BB TRADING SYSTEM",
         text_color=color.white,
         text_size=size.small,
         bgcolor=color.new(color.blue, 40),
         text_halign=text.align_center)
    table.cell(info, 1, 0, "IDBI.NS",
         text_color=color.yellow,
         text_size=size.small,
         bgcolor=color.new(color.blue, 40),
         text_halign=text.align_center)

    // SMA Period
    table.cell(info, 0, 1, "SMA Period",
         text_color=color.gray, text_size=size.small)
    table.cell(info, 1, 1, str.tostring(bb_length),
         text_color=color.white, text_size=size.small)

    // Multiplier
    table.cell(info, 0, 2, "Std Dev (k)",
         text_color=color.gray, text_size=size.small)
    table.cell(info, 1, 2, str.tostring(bb_mult),
         text_color=color.white, text_size=size.small)

    // Stop Loss
    table.cell(info, 0, 3, "Stop Loss",
         text_color=color.gray, text_size=size.small)
    table.cell(info, 1, 3, str.tostring(stop_loss_pct * 100) + "%",
         text_color=color.orange, text_size=size.small)

    // Upper Band
    table.cell(info, 0, 4, "Upper Band",
         text_color=color.gray, text_size=size.small)
    table.cell(info, 1, 4, str.tostring(math.round(upper_band, 2)),
         text_color=color.red, text_size=size.small)

    // SMA
    table.cell(info, 0, 5, "SMA",
         text_color=color.gray, text_size=size.small)
    table.cell(info, 1, 5, str.tostring(math.round(sma, 2)),
         text_color=color.yellow, text_size=size.small)

    // Lower Band
    table.cell(info, 0, 6, "Lower Band",
         text_color=color.gray, text_size=size.small)
    table.cell(info, 1, 6, str.tostring(math.round(lower_band, 2)),
         text_color=color.green, text_size=size.small)
